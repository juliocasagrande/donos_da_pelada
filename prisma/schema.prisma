generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MASTER
  ADMIN
  PLAYER
}

enum PlayerPosition {
  GOLEIRO
  DEFESA
  MEIA
  ATAQUE
}

enum MembershipStatus {
  MENSALISTA
  CONVIDADO
}

enum MatchStatus {
  OPEN
  CLOSED
}

enum MatchSurface {
  SOCIETY
  CAMPO
  QUADRA
}

enum PollStatus {
  OPEN
  CLOSED
}

enum AttendanceStatus {
  CONFIRMED
  WAITLIST
  OUT
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PeladaRole {
  PRESIDENTE
  ADMIN
  JOGADOR
}

enum MatchKind {
  PELADA
  AMISTOSO
}

enum PeladaPlan {
  FREE
  PRO_IN_PROGRESS
  PRO
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DeletionRequestTarget {
  PELADA
  PLAYER
}

enum DeletionVoteValue {
  YES
  NO
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(PLAYER)
  active        Boolean   @default(true)
  onboarded     Boolean   @default(false)
  players       Player[]
  accounts      Account[]
  sessions      Session[]
  votes         PollVote[]
  ratingsGiven  PlayerRating[] @relation("RatingsGiven")
  matchSubmissions PlayerMatchSubmission[] @relation("MatchSubmissions")
  pushSubscriptions PushSubscription[]
  guestInvites Attendance[] @relation("GuestInvites")
  auditLogs    AuditLog[]
  transactions Transaction[]
  peladaMemberships PeladaMembership[]
  createdPeladaInvites PeladaInvite[]
  createdDeletionRequests DeletionRequest[] @relation("CreatedDeletionRequests")
  deletionVotes DeletionVote[]
  peladaJoinRequests PeladaJoinRequest[]
  careerStats   UserCareerStats?
  whatsapp      String?
  whatsappChatEnabled Boolean @default(false)
  pushNotificationsEnabled Boolean @default(false)
  pushPromptDismissed Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Pelada {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  createdByUserId String?
  plan            PeladaPlan         @default(FREE)
  trialEndsAt     DateTime?
  mpSubscriptionId String?           @unique
  mpSubscriptionInterval String?
  subscriptionCancelledAt DateTime?
  mpPaymentPreferenceId String?
  mpPaymentId     String?
  mpPaymentStatus String?
  mpPaymentStatusDetail String?
  mpPaymentError  String?
  mpAuthorizedAmount Float?
  proCancelUntil  DateTime?
  proCancelRollbackUntil DateTime?
  proCaptureAt    DateTime?
  proRenewsAt     DateTime?
  maxLinePlayers   Int                @default(18)
  maxGoalkeepers   Int                @default(2)
  memberships     PeladaMembership[]
  invites         PeladaInvite[]
  joinRequests    PeladaJoinRequest[]
  players         Player[]
  matches         Match[]
  transactions    Transaction[]
  feeConfigs      MonthlyFeeConfig[]
  payments        MonthlyPayment[]
  deletionRequests DeletionRequest[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model DeletionRequest {
  id              String                @id @default(cuid())
  peladaId        String
  target          DeletionRequestTarget
  targetId        String
  targetName      String
  reason          String?
  status          PollStatus             @default(OPEN)
  createdByUserId String?
  createdByUser   User?                 @relation("CreatedDeletionRequests", fields: [createdByUserId], references: [id], onDelete: SetNull)
  pelada          Pelada                @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  votes           DeletionVote[]
  executedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([peladaId, status])
  @@index([target, targetId, status])
}

model DeletionVote {
  id        String              @id @default(cuid())
  requestId String
  userId    String
  vote      DeletionVoteValue
  request   DeletionRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([requestId, userId])
  @@index([userId])
}

model UserCareerStats {
  id            String   @id @default(cuid())
  userId        String   @unique
  goalsTotal    Int      @default(0)
  presenceTotal Int      @default(0)
  craqueTotal   Int      @default(0)
  ratingSum     Float    @default(0)
  ratingCount   Int      @default(0)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt     DateTime @updatedAt
}

model PeladaJoinRequest {
  id        String            @id @default(cuid())
  peladaId  String
  userId    String
  status    JoinRequestStatus @default(PENDING)
  pelada    Pelada            @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([peladaId, userId])
  @@index([peladaId, status])
}

model PeladaMembership {
  id        String     @id @default(cuid())
  userId    String
  peladaId  String
  role      PeladaRole @default(JOGADOR)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pelada    Pelada     @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([userId, peladaId])
  @@index([peladaId])
}

model PeladaInvite {
  id              String     @id @default(cuid())
  peladaId        String
  code            String     @unique @default(cuid())
  role            PeladaRole @default(JOGADOR)
  createdByUserId String?
  maxUses         Int?
  usedCount       Int        @default(0)
  expiresAt       DateTime?
  revokedAt       DateTime?
  pelada          Pelada     @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  createdByUser   User?      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime   @default(now())

  @@index([peladaId])
}

model MonthlyFeeConfig {
  id        String   @id @default(cuid())
  peladaId  String
  pelada    Pelada   @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  year      Int
  month     Int
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([peladaId, year, month])
}

model MonthlyPayment {
  id        String   @id @default(cuid())
  peladaId  String
  pelada    Pelada   @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  playerId  String
  year      Int
  month     Int
  amount    Float
  paidAt    DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([peladaId, playerId, year, month])
}

model Transaction {
  id              String          @id @default(cuid())
  peladaId        String
  pelada          Pelada          @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  type            TransactionType
  description     String
  amount          Float
  date            DateTime
  createdByUserId String?
  createdByUser   User?           @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())

  @@index([peladaId, date])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userName   String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh     String
  auth      String
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Player {
  id          String            @id @default(cuid())
  userId      String?
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  peladaId    String
  pelada      Pelada            @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  nickname    String
  photoUrl    String?
  position    PlayerPosition
  membershipStatus MembershipStatus @default(MENSALISTA)
  rating      Float             @default(0)
  ratingAssigned Boolean        @default(false)
  active      Boolean           @default(true)
  attendances Attendance[]
  teamPlayers TeamPlayer[]
  goals       Goal[]
  assists     Assist[]
  defenses    DifficultSave[]
  ratings     PlayerRating[]   @relation("PlayerRatings")
  matchSubmissions PlayerMatchSubmission[] @relation("PlayerSubmissions")
  pollVotes   PollVote[]
  pollWinners Poll[]            @relation("PollWinner")
  payments    MonthlyPayment[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([userId, peladaId])
  @@index([peladaId])
}

model Match {
  id          String            @id @default(cuid())
  peladaId    String
  pelada      Pelada            @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  date        DateTime
  title       String
  status      MatchStatus       @default(OPEN)
  kind        MatchKind         @default(PELADA)
  surface     MatchSurface      @default(SOCIETY)
  location    String?
  opponentName String?
  homeScore   Int?
  awayScore   Int?
  closeReminderSentAt DateTime?
  attendances Attendance[]
  teams       Team[]
  goals       Goal[]
  assists     Assist[]
  defenses    DifficultSave[]
  ratings     PlayerRating[]
  playerSubmissions PlayerMatchSubmission[]
  polls       Poll[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([peladaId])
}

model Attendance {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  present   Boolean  @default(false)
  status    AttendanceStatus @default(OUT)
  invitedByUserId String?
  invitedByUser User? @relation("GuestInvites", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  confirmedAt DateTime?
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
}

model Team {
  id          String       @id @default(cuid())
  matchId     String
  name        String
  totalRating Float        @default(0)
  match       Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  players     TeamPlayer[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamPlayer {
  id        String   @id @default(cuid())
  teamId    String
  playerId  String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([teamId, playerId])
}

model Goal {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  quantity  Int      @default(0)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
}

model Assist {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  quantity  Int      @default(0)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
}

model DifficultSave {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  quantity  Int      @default(0)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
}

model Poll {
  id          String     @id @default(cuid())
  matchId     String
  title       String
  status      PollStatus @default(OPEN)
  winnerId    String?
  match       Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winner      Player?    @relation("PollWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  votes       PollVote[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  userId    String
  playerId  String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([pollId, userId])
}

model PlayerRating {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  userId    String
  value     Float
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation("PlayerRatings", fields: [playerId], references: [id], onDelete: Cascade)
  user      User     @relation("RatingsGiven", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId, userId])
}

model PlayerMatchSubmission {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  userId    String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation("PlayerSubmissions", fields: [playerId], references: [id], onDelete: Cascade)
  user      User     @relation("MatchSubmissions", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([matchId, playerId, userId])
}
