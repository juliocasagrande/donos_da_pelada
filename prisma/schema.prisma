generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MASTER
  ADMIN
  PLAYER
}

enum PlayerPosition {
  GOLEIRO
  DEFESA
  MEIA
  ATAQUE
}

enum MembershipStatus {
  MENSALISTA
  CONVIDADO
}

enum MatchStatus {
  OPEN
  CLOSED
}

enum MatchSurface {
  SOCIETY
  CAMPO
  QUADRA
}

enum PollStatus {
  OPEN
  CLOSED
}

enum AttendanceStatus {
  CONFIRMED
  WAITLIST
  OUT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(PLAYER)
  active        Boolean   @default(true)
  onboarded     Boolean   @default(false)
  player        Player?
  accounts      Account[]
  sessions      Session[]
  votes         PollVote[]
  ratingsGiven  PlayerRating[] @relation("RatingsGiven")
  matchSubmissions PlayerMatchSubmission[] @relation("MatchSubmissions")
  pushSubscriptions PushSubscription[]
  guestInvites Attendance[] @relation("GuestInvites")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh     String
  auth      String
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Player {
  id          String            @id @default(cuid())
  userId      String?           @unique
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  nickname    String?
  photoUrl    String?
  position    PlayerPosition
  membershipStatus MembershipStatus @default(MENSALISTA)
  rating      Float             @default(0)
  ratingAssigned Boolean        @default(false)
  active      Boolean           @default(true)
  attendances Attendance[]
  teamPlayers TeamPlayer[]
  goals       Goal[]
  assists     Assist[]
  defenses    DifficultSave[]
  ratings     PlayerRating[]   @relation("PlayerRatings")
  matchSubmissions PlayerMatchSubmission[] @relation("PlayerSubmissions")
  pollVotes   PollVote[]
  pollWinners Poll[]            @relation("PollWinner")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Match {
  id          String            @id @default(cuid())
  date        DateTime
  title       String
  status      MatchStatus       @default(OPEN)
  surface     MatchSurface      @default(SOCIETY)
  location    String?
  attendances Attendance[]
  teams       Team[]
  goals       Goal[]
  assists     Assist[]
  defenses    DifficultSave[]
  ratings     PlayerRating[]
  playerSubmissions PlayerMatchSubmission[]
  polls       Poll[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Attendance {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  present   Boolean  @default(false)
  status    AttendanceStatus @default(OUT)
  invitedByUserId String?
  invitedByUser User? @relation("GuestInvites", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  confirmedAt DateTime?
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
}

model Team {
  id          String       @id @default(cuid())
  matchId     String
  name        String
  totalRating Float        @default(0)
  match       Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  players     TeamPlayer[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamPlayer {
  id        String   @id @default(cuid())
  teamId    String
  playerId  String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([teamId, playerId])
}

model Goal {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  quantity  Int      @default(0)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
}

model Assist {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  quantity  Int      @default(0)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
}

model DifficultSave {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  quantity  Int      @default(0)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
}

model Poll {
  id          String     @id @default(cuid())
  matchId     String
  title       String
  status      PollStatus @default(OPEN)
  winnerId    String?
  match       Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winner      Player?    @relation("PollWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  votes       PollVote[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  userId    String
  playerId  String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([pollId, userId])
}

model PlayerRating {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  userId    String
  value     Float
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation("PlayerRatings", fields: [playerId], references: [id], onDelete: Cascade)
  user      User     @relation("RatingsGiven", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId, userId])
}

model PlayerMatchSubmission {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  userId    String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation("PlayerSubmissions", fields: [playerId], references: [id], onDelete: Cascade)
  user      User     @relation("MatchSubmissions", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([matchId, playerId, userId])
}
