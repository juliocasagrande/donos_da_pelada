# Pooled connection (Neon dashboard > Connection Details > "Pooled connection").
# Required on Vercel/serverless so each function invocation reuses PgBouncer
# instead of opening a fresh Postgres connection.
DATABASE_URL="postgresql://user:password@host-pooler/database?sslmode=require&pgbouncer=true&connection_limit=1"
# Direct (unpooled) connection, same host without "-pooler" - only used by
# `prisma migrate`/`prisma db push`, which need a real session, not PgBouncer.
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="troque-este-segredo"

